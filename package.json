{
  "name": "focused-agent",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=24 <25"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "puppeteer"
    ]
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/db-migrate.ts",
    "db:seed": "tsx scripts/db-seed.ts",
    "db:setup": "tsx scripts/db-setup.ts",
    "accounting:generate-seed-embeddings": "tsx scripts/generate-seed-embeddings.ts",
    "accounting:index-purchase-orders": "tsx scripts/index-purchase-orders.ts",
    "agent:worker": "tsx scripts/reconciliation-worker.ts",
    "agent:graph": "tsx scripts/print-agent-graph.ts",
    "fixtures:generate": "uv run --script scripts/generate-invoice-documents.py",
    "eval:dataset:sync": "tsx evals/reconciliation/sync-dataset.ts",
    "eval:run": "tsx evals/reconciliation/run-experiment.ts",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1090.0",
    "@langchain/core": "^1.0.0",
    "@langchain/langgraph": "^1.0.0",
    "@langchain/langgraph-checkpoint": "^1.0.0",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.0",
    "@langchain/openai": "^1.0.0",
    "dotenv": "^17.0.0",
    "drizzle-orm": "^0.45.2",
    "file-type": "^22.0.1",
    "next": "^16.2.0",
    "nodemailer": "^9.0.3",
    "pg": "^8.16.0",
    "pg-boss": "^12.26.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "^11.16.0",
    "@playwright/test": "^1.54.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.0",
    "@types/node": "^24.0.0",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.30.0",
    "eslint-config-next": "^16.2.0",
    "jsdom": "^26.1.0",
    "langsmith": "^0.8.3",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
