# Host-based development. Docker Compose overrides the hostname with `db`.
DATABASE_URL=postgresql://focused_agent:focused_agent@localhost:5432/focused_agent

# Local S3-compatible document storage.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=invoice-documents
S3_ACCESS_KEY_ID=focused_agent
S3_SECRET_ACCESS_KEY=focused_agent_secret
S3_FORCE_PATH_STYLE=true

# Local SMTP capture. Browse captured messages at http://localhost:8025.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=reconciliation@example.test

# Explicitly opt into deterministic mock accounting records.
SEED_DEMO_DATA=true

# Required by the reconciliation worker, evals, and semantic PO indexing/search.
OPENAI_API_KEY=

# LangChain model identifier used for extraction, line matching, and email drafting.
AGENT_MODEL=gpt-5.6-luna

# Optional for application tracing; required by the explicit eval commands.
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=focused-agent
